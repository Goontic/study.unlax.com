generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  passwordHash        String
  displayName         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  answers             UserAnswer[]
  favorites           UserFavorite[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

enum SchoolLevel {
  elementary
  middle
  exam_prep
}

// school_education: 学校の教科書に沿った学習（小学校・中学校・高校入試対策）
// certification: 英検・漢検・数検など学校教育とは別軸の検定試験
enum Genre {
  school_education
  certification
}

model Subject {
  id           Int         @id @default(autoincrement())
  slug         String      @unique
  name         String
  icon         String
  displayOrder Int         @default(0)
  genre        Genre       @default(school_education)
  // genre = school_education の場合にのみ意味を持つ（小学生/中学生/高校入試対策の区分）
  schoolLevel  SchoolLevel @default(middle)
  topics       Topic[]

  @@map("subjects")
}

model Topic {
  id           Int        @id @default(autoincrement())
  subjectId    Int
  slug         String
  name         String
  // 学校教育科目では学年(1〜6等)、検定科目では級を表す汎用フィールド
  gradeLevel   Int
  displayOrder Int        @default(0)
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions    Question[]

  @@unique([subjectId, slug])
  @@map("topics")
}

enum QuestionType {
  multiple_choice
  text_input
  fill_blank
  ordering
}

model Question {
  id           Int                   @id @default(autoincrement())
  topicId      Int
  type         QuestionType
  body         String
  difficulty   Int                   @default(3)
  displayOrder Int                   @default(0)
  createdAt    DateTime              @default(now())
  topic        Topic                 @relation(fields: [topicId], references: [id], onDelete: Cascade)
  choices      QuestionChoice[]
  blankAnswers QuestionBlankAnswer[]
  orderItems   QuestionOrderItem[]
  steps        QuestionStep[]
  answers      UserAnswer[]
  favorites    UserFavorite[]

  @@map("questions")
}

model QuestionChoice {
  id           Int      @id @default(autoincrement())
  questionId   Int
  body         String
  isCorrect    Boolean  @default(false)
  displayOrder Int      @default(0)
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_choices")
}

model QuestionBlankAnswer {
  id            Int      @id @default(autoincrement())
  questionId    Int
  blankIndex    Int
  correctAnswer String
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_blank_answers")
}

model QuestionOrderItem {
  id              Int      @id @default(autoincrement())
  questionId      Int
  body            String
  correctPosition Int
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_order_items")
}

model QuestionStep {
  id         Int      @id @default(autoincrement())
  questionId Int
  stepNumber Int
  body       String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_steps")
}

model UserAnswer {
  id         Int      @id @default(autoincrement())
  userId     Int
  questionId Int
  isCorrect  Boolean
  answeredAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("user_answers")
}

model UserFavorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  questionId Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_favorites")
}
