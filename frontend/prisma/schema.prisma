generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  passwordHash String         @map("password_hash")
  displayName  String         @map("display_name")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  answers      UserAnswer[]
  favorites    UserFavorite[]

  @@map("users")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

enum SchoolLevel {
  elementary
  middle
  exam_prep
}

// school_education: 学校の教科書に沿った学習（小学校・中学校・高校入試対策）
// certification: 英検・漢検・数検など学校教育とは別軸の検定試験
enum Genre {
  school_education
  certification
}

model Subject {
  id           Int         @id @default(autoincrement())
  slug         String      @unique
  name         String
  icon         String
  displayOrder Int         @default(0) @map("display_order")
  genre        Genre       @default(school_education)
  // genre = school_education の場合にのみ意味を持つ（小学生/中学生/高校入試対策の区分）
  schoolLevel  SchoolLevel @default(middle) @map("school_level")
  topics       Topic[]

  @@map("subjects")
}

model Topic {
  id           Int        @id @default(autoincrement())
  subjectId    Int        @map("subject_id")
  slug         String
  name         String
  // 学校教育科目では学年(1〜6等)、検定科目では級を表す汎用フィールド
  gradeLevel   Int        @map("grade_level")
  // 単元の要点まとめ（公開ページに表示するSEO用解説。改行区切りの平文）
  description  String?
  displayOrder Int        @default(0) @map("display_order")
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions    Question[]

  @@unique([subjectId, slug])
  @@map("topics")
}

enum QuestionType {
  multiple_choice
  text_input
  fill_blank
  ordering
}

model Question {
  id           Int                   @id @default(autoincrement())
  topicId      Int                   @map("topic_id")
  type         QuestionType
  body         String
  difficulty   Int                   @default(3)
  displayOrder Int                   @default(0) @map("display_order")
  createdAt    DateTime              @default(now()) @map("created_at")
  topic        Topic                 @relation(fields: [topicId], references: [id], onDelete: Cascade)
  choices      QuestionChoice[]
  blankAnswers QuestionBlankAnswer[]
  orderItems   QuestionOrderItem[]
  steps        QuestionStep[]
  answers      UserAnswer[]
  favorites    UserFavorite[]

  @@map("questions")
}

model QuestionChoice {
  id           Int      @id @default(autoincrement())
  questionId   Int      @map("question_id")
  body         String
  isCorrect    Boolean  @default(false) @map("is_correct")
  displayOrder Int      @default(0) @map("display_order")
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_choices")
}

model QuestionBlankAnswer {
  id            Int      @id @default(autoincrement())
  questionId    Int      @map("question_id")
  blankIndex    Int      @map("blank_index")
  correctAnswer String   @map("correct_answer")
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_blank_answers")
}

model QuestionOrderItem {
  id              Int      @id @default(autoincrement())
  questionId      Int      @map("question_id")
  body            String
  correctPosition Int      @map("correct_position")
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_order_items")
}

model QuestionStep {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  stepNumber Int      @map("step_number")
  body       String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_steps")
}

model UserAnswer {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  isCorrect  Boolean  @map("is_correct")
  answeredAt DateTime @default(now()) @map("answered_at")
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("user_answers")
}

model UserFavorite {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_favorites")
}
